	(text "This PCB was designed to control a mechanical 7 segment display that serves as Pomodoro timer. On top \nof the servos and mechanical display it also includes speakers to create an alarm noise and mechanical \nswitches and a rotary encoder switch to pause the timer as well as set the amount of time it runs for."
		(exclude_from_sim no)
		(at 178.816 172.974 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0ca2f599-2518-4faf-97be-53d6d3015a03")
	)
	(text "This circuit was created copying\nthe refrence circuit on the \nMAX98357 Audio Driver for \nmono audio."
		(exclude_from_sim no)
		(at 186.944 68.072 0)
